{
  "name": "env-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:next": "node scripts/next-dev.mjs",
    "build:next:prod": "node scripts/next-build.mjs",
    "build:rspack": "pnpm run build:rspack:dev",
    "build:rspack:dev": "rspack build --config rspack.config.ts --mode development",
    "build:rspack:prod": "rspack build --config rspack.config.ts --mode production",
    "build:vite": "pnpm run build:vite:dev",
    "build:vite:dev": "vite build --mode development",
    "build:vite:prod": "vite build --mode production",
    "build:webpack": "pnpm run build:webpack:dev",
    "build:webpack:dev": "webpack --config webpack.config.mjs --mode development",
    "build:webpack:prod": "webpack --config webpack.config.mjs --mode production",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@swc/core": "^1.15.30",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "html-webpack-plugin": "^5.6.7",
    "next": "^16.2.9",
    "swc-loader": "^0.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
